# Grok Deep Search configuration
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will NOT be committed.

# Required — your API key from the Grok-compatible gateway (for example grok2api)
GROK_API_KEY=sk-your-key-here

# Optional — base URL of the OpenAI-compatible endpoint
GROK_BASE_URL=http://localhost:3005/v1

# Optional — model name
GROK_MODEL=grok-4.20-beta
